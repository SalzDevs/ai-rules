{
  "name": "ai-rules",
  "version": "0.2.0",
  "description": "Local-first, tool-agnostic AI coding instruction selector and wrapper.",
  "type": "module",
  "main": "./dist/bin/ai-rules.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "ai-rules": "./dist/bin/ai-rules.js",
    "smart-opencode": "./dist/bin/smart-opencode.js",
    "smart-pi": "./dist/bin/smart-pi.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run build",
    "test": "node --import tsx --test --test-concurrency=1 test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SalzDevs/ai-rules.git"
  },
  "homepage": "https://github.com/SalzDevs/ai-rules#readme",
  "bugs": {
    "url": "https://github.com/SalzDevs/ai-rules/issues"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "rules",
    "prompt",
    "opencode",
    "pi"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "minimatch": "^10.0.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
